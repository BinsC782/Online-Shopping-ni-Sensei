<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shopping.MainController">
   <!-- Header Section -->
   <children>
      <!-- Top Navigation Bar -->
      <HBox fx:id="headerBar" alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar">
         <children>
            <!-- Logo/Brand -->
            <Label fx:id="logoLabel" text="🛒 PowerPuffGirls Shopping" styleClass="logo-label">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>

            <!-- Spacer to push search to center -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Search Section -->
            <HBox fx:id="searchSection" alignment="CENTER" spacing="10.0" styleClass="search-section">
               <children>
                  <TextField fx:id="searchField" promptText="Search products..." prefWidth="350.0" styleClass="search-field" />
                  <Button fx:id="searchButton" text="🔍 Search" styleClass="search-button" />
               </children>
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="SOMETIMES" />

            <!-- User Actions -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0" styleClass="user-actions">
               <children>
                  <Label fx:id="cartTotalLabel" text="Total: $0.00" styleClass="cart-total-label" />
                  <Button fx:id="checkoutButton" text="🛒 Checkout" styleClass="checkout-button" />
                  <Button fx:id="logoutButton" text="Logout" styleClass="logout-button" />
               </children>
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </HBox>
         </children>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </HBox>

      <!-- Category Navigation -->
      <HBox fx:id="categoryBar" alignment="CENTER_LEFT" spacing="15.0" styleClass="category-bar">
         <children>
            <Label text="Categories:" styleClass="categories-label">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <ToggleButton fx:id="allCategoriesBtn" text="All Categories" styleClass="category-button, active-category" selected="true" />
            <ToggleButton fx:id="accessoriesBtn" text="Accessories" styleClass="category-button" />
            <ToggleButton fx:id="homeLifestyleBtn" text="Home &amp; Lifestyle" styleClass="category-button" />
            <ToggleButton fx:id="electronicsBtn" text="Electronics" styleClass="category-button" />
            <ToggleButton fx:id="fashionBtn" text="Fashion" styleClass="category-button" />
         </children>
         <VBox.margin>
            <Insets bottom="15.0" left="20.0" right="20.0" top="10.0" />
         </VBox.margin>
      </HBox>

      <!-- Products Display Area -->
      <ScrollPane fx:id="productsScrollPane" fitToWidth="true" fitToHeight="true" styleClass="products-scroll-pane">
         <content>
            <TilePane fx:id="productGrid" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" prefColumns="4" styleClass="product-grid">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </TilePane>
         </content>
      </ScrollPane>
   </children>
</VBox>
